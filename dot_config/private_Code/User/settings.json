{
  // don't autoupdate extensions, because security
  // > NX Console Extension that can be used in VSCode, Cursor, etc compromised some users due to its auto-update feature.
  // ref: https://semgrep.dev/blog/2025/security-alert-nx-compromised-to-steal-wallets-and-credentials/
  "extensions.autoUpdate": false,
  "extensions.experimental.affinity": {
    // to speed up the extension
    // ref: https://github.com/vscode-neovim/vscode-neovim/issues/1051
    "asvetliakov.vscode-neovim": 1
  },
  // fixes key remapping (caps lock and esc swap)
  // ref: https://stackoverflow.com/questions/48369303/use-in-visual-studio-code-vim-extension-caps-instead-of-esc/50875402#50875402
  // ref: https://github.com/microsoft/vscode/issues/23991#issuecomment-292336504
  "keyboard.dispatch": "keyCode",
  "editor.rulers": [
    {
      "column": 80
    },
    {
      "column": 120
    }
  ],
  "telemetry.telemetryLevel": "off",
  "workbench.sideBar.location": "right",
  "terminal.integrated.confirmOnExit": "always",
  "debug.confirmOnExit": "always",
  // the vim way
  "editor.lineNumbers": "relative",
  "markdown.preview.fontSize": 20,
  "svg.preview.mode": "svg",
  // show commit message input validation diagnostics
  "git.inputValidation": true,
  "editor.mouseWheelZoom": true,
  // show moved code blocks
  "diffEditor.experimental.showMoves": true,
  "chat.mcp.access": "none",
  "github.copilot.nextEditSuggestions.enabled": true,
  // don't want copilot chat to be open by default
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "editor.fontFamily": "DejaVuSansM Nerd Font Propo",
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": true,
  "editor.renderWhitespace": "boundary",
  "editor.stickyScroll.enabled": false,
  "cSpell.userWords": ["backpropagation"],
  "vscode-neovim.neovimExecutablePaths.linux": "/home/cshubh/.local/bin/nvim",
  "terminal.integrated.stickyScroll.enabled": false,
  "files.associations": {
    "*.h": "c"
  },
  "makefile.configureOnOpen": true,
  "svelte.enable-ts-plugin": true,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "tailwindCSS.classFunctions": ["clsx"],
  "tailwindCSS.validate": true,
  "tailwindCSS.lint.invalidScreen": "warning",
  "tailwindCSS.lint.invalidVariant": "warning",
  "tailwindCSS.lint.invalidTailwindDirective": "warning",
  "tailwindCSS.lint.invalidApply": "warning",
  "tailwindCSS.lint.invalidConfigPath": "warning",
  "tailwindCSS.lint.cssConflict": "warning",
  "tailwindCSS.lint.recommendedVariantOrder": "warning",
  "tailwindCSS.lint.usedBlocklistedClass": "warning",
  "ruff.configuration": "",
  "rust-analyzer.check.command": "clippy",
  "vscode-neovim.ctrlKeysForNormalMode": [
    "a",
    // "b", // workbench.action.toggleSidebarVisibility
    "c",
    "d",
    "e",
    "f",
    "h",
    "i",
    "j",
    "k",
    "l",
    "m",
    "o",
    "r",
    "t",
    "u",
    "v",
    "w",
    "x",
    "y",
    "z",
    "/",
    "]",
    "right",
    "left",
    "up",
    "down",
    "backspace",
    "delete"
  ],
  "git.blame.editorDecoration.enabled": true,
  "better-comments.highlightPlainText": true,
  "bootstrapIntelliSense": {
    "enable": true,
    "bsVersion": "5.3.7",
    "useLocalFile": false,
    "cssFilePath": "",
    "languageSupport": ["astro"]
  },
  // ----------------------- language specific settings -----------------------
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[sql]": {
    "editor.defaultFormatter": "ReneSaarsoo.sql-formatter-vsc"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[rust]": {
    "editor.tabSize": 4
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "[mdx]": {
    "editor.defaultFormatter": "unifiedjs.vscode-mdx"
  },
  "[just]": {
    "editor.defaultFormatter": "nefrob.vscode-just-syntax"
  },
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  }
}
